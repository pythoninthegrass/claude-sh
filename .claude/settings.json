{
  "permissions": {
    "allow": [
      "Bash(bats:*)",
      "Bash(jq:*)",
      "Bash(prek:*)"
    ],
    "deny": [ ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "git diff --name-only HEAD | xargs -r prek run --files"
          }
        ]
      }
    ]
  }
}
